# Copy to `.env` (which is git-ignored) to override docker-compose defaults.

# JWT signing key used by the API (must be at least 32 bytes).
# A demo default is baked into docker-compose.yml so `docker compose up` works
# out of the box, but set your own here for anything beyond local play.
JWT_KEY=change-me-to-a-long-random-secret-at-least-32-bytes

# Host port the web app is published on (default 8080).
WEB_PORT=8080
